# Required
OUTLIER_COOKIE=""

# Optional server config
LISTEN_ADDR=":8080"
OUTLIER_BASE_URL="https://playground.outlier.ai"
OUTLIER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"
OUTLIER_ORIGIN="https://playground.outlier.ai"
OUTLIER_REFERER="https://playground.outlier.ai/"

# Models cache
OUTLIER_MODELS_CACHE_FILE="models_cache.json"
# OUTLIER_MODELS_CACHE_TTL="24h"  # Optional. Empty/unset = never expire.

# New conversation preflight request (GET /?_rsc=<value>)
OUTLIER_NEW_CONV_RSC="1h3ay"

# Request control
# OUTLIER_BLOCKING_MODE="false"  # true = serialize chat requests with a semaphore
# OUTLIER_RPM="0"                # 0 = unlimited; >0 = max chat requests per minute (429 when exceeded)
